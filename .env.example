# Feishu App Credentials (required)
# Obtain from Feishu Developer Console after creating a self-built app
FEISHU_APP_ID=your_app_id_here
FEISHU_APP_SECRET=your_app_secret_here

# Koa HTTP server port (optional, default: 3000)
# PORT=3000

# OpenCode executable path (optional, defaults to "opencode" in PATH)
# OPENCODE_PATH=/path/to/opencode

# OpenCode ACP server port (optional, default: 4096)
# OPENCODE_PORT=4096

# OpenCode working directory (optional, default: ./output)
# OPENCODE_CWD=./output

# OpenCode startup timeout in ms (optional, default: 30000)
# OPENCODE_STARTUP_TIMEOUT=30000

# Log level: fatal, error, warn, info, debug, trace (optional, default: info)
# LOG_LEVEL=info

# Node environment (optional, default: development)
# NODE_ENV=development